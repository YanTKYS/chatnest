<Window x:Class="ChatNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ChatNest.Converters"
        xmlns:vm="clr-namespace:ChatNest.ViewModels"
        xmlns:models="clr-namespace:ChatNest.Models"
        Title="ChatNest"
        Width="760" Height="620"
        MinWidth="520" MinHeight="420"
        Background="#F5F5F7"
        FontFamily="Yu Gothic UI, Meiryo UI, sans-serif">

    <Window.Resources>
        <conv:SpeakerBackgroundConverter x:Key="SpeakerBg"/>
        <conv:SpeakerAccentConverter x:Key="SpeakerAccent"/>
        <conv:SpeakerAlignmentConverter x:Key="SpeakerAlign"/>
        <conv:SpeakerBorderThicknessConverter x:Key="SpeakerBorderThickness"/>
        <conv:SpeakerLabelAlignmentConverter x:Key="SpeakerLabelAlign"/>
        <conv:SpeakerButtonAlignmentConverter x:Key="SpeakerBtnAlign"/>
        <conv:SpeakerTextAlignmentConverter x:Key="SpeakerTextAlign"/>

        <!-- Message bubble template -->
        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type models:Message}">
            <Grid Margin="16,4">
                <Border HorizontalAlignment="{Binding Speaker, Converter={StaticResource SpeakerAlign}}"
                        MaxWidth="500"
                        CornerRadius="10"
                        Background="{Binding Speaker, Converter={StaticResource SpeakerBg}}"
                        BorderBrush="{Binding Speaker, Converter={StaticResource SpeakerAccent}}"
                        BorderThickness="{Binding Speaker, Converter={StaticResource SpeakerBorderThickness}}">
                    <Grid Margin="14,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header row: speaker label + delete button -->
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Speaker}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{Binding Speaker, Converter={StaticResource SpeakerAccent}}"
                                       HorizontalAlignment="{Binding Speaker, Converter={StaticResource SpeakerLabelAlign}}"/>

                            <Button Grid.Column="1"
                                    Style="{StaticResource IconButton}"
                                    Content="✕"
                                    ToolTip="この発言を削除"
                                    VerticalAlignment="Top"
                                    Command="{Binding DataContext.DeleteMessageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>

                        <!-- Message text -->
                        <TextBlock Grid.Row="1"
                                   Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   LineHeight="20"
                                   Foreground="#212121"
                                   TextAlignment="{Binding Speaker, Converter={StaticResource SpeakerTextAlign}}"
                                   Margin="0,0,0,6"/>

                        <!-- Timestamp -->
                        <TextBlock Grid.Row="2"
                                   Text="{Binding CreatedAt, StringFormat=HH:mm}"
                                   FontSize="10"
                                   Foreground="#9E9E9E"
                                   HorizontalAlignment="{Binding Speaker, Converter={StaticResource SpeakerLabelAlign}}"/>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0"
                Background="White"
                Padding="20,14,16,14">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="8" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ChatNest"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1976D2"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="一時的な思考ログ"
                               FontSize="11"
                               Foreground="#9E9E9E"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Button Style="{StaticResource GhostButton}"
                            Content="Markdownコピー"
                            ToolTip="全件をMarkdown形式でコピー"
                            Margin="0,0,6,0"
                            Command="{Binding CopyMarkdownCommand}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="IdeaNest用コピー"
                            ToolTip="IdeaNest貼り付け用にコピー"
                            Margin="0,0,6,0"
                            Command="{Binding CopyIdeaNestCommand}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="保存"
                            ToolTip="ファイルに保存"
                            Margin="0,0,6,0"
                            Command="{Binding SaveCommand}"/>
                    <Button Style="{StaticResource GhostButton}"
                            Content="開く"
                            ToolTip=".chatnesファイルを開く"
                            Margin="0,0,6,0"
                            Command="{Binding LoadCommand}"/>
                    <Button Style="{StaticResource DangerButton}"
                            Content="全件削除"
                            ToolTip="すべての発言を削除"
                            Command="{Binding DeleteAllCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== CHAT LOG ========== -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,8,0,8"
                      Background="Transparent">
            <ItemsControl ItemsSource="{Binding Messages}"
                          ItemTemplate="{StaticResource MessageTemplate}"
                          VirtualizingPanel.IsVirtualizing="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="💬"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
            <TextBlock Text="発言者を選んで、考えを書き出そう"
                       FontSize="14"
                       Foreground="#BDBDBD"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ctrl + Enter で投稿"
                       FontSize="11"
                       Foreground="#D0D0D0"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- ========== INPUT AREA ========== -->
        <Border Grid.Row="2"
                Background="White"
                Padding="16,12,16,14">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="-2" Direction="90"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Speaker selector -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">
                    <TextBlock Text="発言者："
                               FontSize="11"
                               Foreground="#757575"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <RadioButton Style="{StaticResource SpeakerToggle}"
                                 Content="自分"
                                 IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=自分, Mode=TwoWay}"
                                 GroupName="Speaker"/>
                    <RadioButton Style="{StaticResource SpeakerToggle}"
                                 Content="反論"
                                 IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=反論, Mode=TwoWay}"
                                 GroupName="Speaker"/>
                    <RadioButton Style="{StaticResource SpeakerToggle}"
                                 Content="補足"
                                 IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=補足, Mode=TwoWay}"
                                 GroupName="Speaker"/>
                    <RadioButton Style="{StaticResource SpeakerToggle}"
                                 Content="要約"
                                 IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=要約, Mode=TwoWay}"
                                 GroupName="Speaker"/>
                </StackPanel>

                <!-- Input row: TextBox + Post button -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,10,0">
                        <TextBox x:Name="InputBox"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="52"
                                 MaxHeight="120"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13"
                                 Padding="10,8"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Top"
                                 PreviewKeyDown="InputBox_PreviewKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="{TemplateBinding Padding}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryButton}"
                            Content="投稿"
                            Width="70"
                            VerticalAlignment="Bottom"
                            Command="{Binding PostCommand}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
